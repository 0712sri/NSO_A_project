#!/bin/bash

if [ "$#" -ne 3 ]; then
    echo "Usage: ./install <openrc> <tag> <ssh_key>"
    exit 1
fi

OPENRC=$1
TAG=$2
SSH_KEY=$3

source $OPENRC
echo "Starting deployment: $TAG"

# ---- NODE COUNT ----
NODE_COUNT=$(grep -E '^[0-9]+$' servers.conf | head -1)
echo "Node count: $NODE_COUNT"

# ---- KEYPAIR ----
if ! openstack keypair show ${TAG}_key &>/dev/null; then
    echo "Creating keypair..."
    openstack keypair create --public-key ${SSH_KEY}.pub ${TAG}_key
fi

# ---- NETWORK ----
if ! openstack network show ${TAG}_network &>/dev/null; then
    echo "Creating network..."
    openstack network create ${TAG}_network
    openstack subnet create \
        --network ${TAG}_network \
        --subnet-range 192.168.1.0/24 \
        ${TAG}_subnet
fi

NETWORK_ID=$(openstack network show ${TAG}_network -f value -c id)

# ---- ROUTER ----
if ! openstack router show ${TAG}_router &>/dev/null; then
    echo "Creating router..."
    openstack router create ${TAG}_router
fi

openstack router set --external-gateway External ${TAG}_router 2>/dev/null || true
openstack router add subnet ${TAG}_router ${TAG}_subnet 2>/dev/null || true

# ---- SECURITY GROUP ----
if ! openstack security group show ${TAG}_sg &>/dev/null; then
    echo "Creating security group..."
    openstack security group create ${TAG}_sg
fi

openstack security group rule create --proto tcp --dst-port 22 ${TAG}_sg 2>/dev/null || true
openstack security group rule create --proto tcp --dst-port 5000 ${TAG}_sg 2>/dev/null || true
openstack security group rule create --proto udp --dst-port 6000 ${TAG}_sg 2>/dev/null || true
openstack security group rule create --proto icmp ${TAG}_sg 2>/dev/null || true

# ---- FLOATING IP ----
AVAILABLE_IPS=$(openstack floating ip list --status DOWN -f value -c "Floating IP Address")
IP_COUNT=$(echo "$AVAILABLE_IPS" | grep -c '[0-9]' || true)

if [ "$IP_COUNT" -ge 2 ]; then
    BASTION_IP=$(echo "$AVAILABLE_IPS" | sed -n '1p')
    PROXY_IP=$(echo "$AVAILABLE_IPS" | sed -n '2p')
else
    BASTION_IP=$(openstack floating ip create External -f value -c floating_ip_address)
    PROXY_IP=$(openstack floating ip create External -f value -c floating_ip_address)
fi

# ---- IMAGE ----
IMAGE=$(openstack image list -f value -c Name | grep -i "Ubuntu 20.04" | head -1)
[ -z "$IMAGE" ] && echo "ERROR: No Ubuntu image" && exit 1

FLAVOR="small"

# ---- CREATE SERVER ----
create_server() {
    NAME=$1
    if ! openstack server show $NAME &>/dev/null; then
        echo "Launching $NAME"
        openstack server create \
            --image "$IMAGE" \
            --flavor $FLAVOR \
            --key-name ${TAG}_key \
            --network $NETWORK_ID \
            --security-group ${TAG}_sg \
            $NAME
    else
        echo "$NAME exists"
    fi
}

# ---- CREATE SERVERS ----
create_server ${TAG}_bastion
create_server ${TAG}_proxy

for i in $(seq 1 $NODE_COUNT); do
    create_server ${TAG}_node${i}
done

# ---- WAIT ----
echo "Waiting for servers..."
for i in {1..30}; do
    TOTAL=$(openstack server list -f value -c Name | grep -c "${TAG}_")
    ACTIVE=$(openstack server list -f value -c Name -c Status | grep "${TAG}_" | grep -c ACTIVE)

    if [ "$TOTAL" -gt 0 ] && [ "$ACTIVE" -eq "$TOTAL" ]; then
        echo "All servers ACTIVE"
        break
    fi

    echo -n "."
    sleep 10
done

# ---- FLOATING IP ATTACH ----
openstack server add floating ip ${TAG}_bastion $BASTION_IP 2>/dev/null
openstack server add floating ip ${TAG}_proxy $PROXY_IP 2>/dev/null

echo "Deployment complete!"