#!/bin/bash

if [ "$#" -ne 3 ]; then
    echo "Usage: ./install <openrc> <tag> <ssh_key>"
    exit 1
fi

OPENRC=$1
TAG=$2
SSH_KEY=$3

source $OPENRC

echo "Starting deployment: $TAG"

# ---- NODE COUNT ----
NODE_COUNT=$(cat servers.conf)

# ---- FLOATING IPs ----
AVAILABLE_IPS=$(openstack floating ip list --status DOWN -f value -c "Floating IP Address")
IP_COUNT=$(echo "$AVAILABLE_IPS" | grep -c '[0-9]' || true)

if [ "$IP_COUNT" -ge 2 ]; then
    BASTION_IP=$(echo "$AVAILABLE_IPS" | sed -n '1p')
    PROXY_IP=$(echo "$AVAILABLE_IPS" | sed -n '2p')
else
    BASTION_IP=$(openstack floating ip create External -f value -c floating_ip_address)
    PROXY_IP=$(openstack floating ip create External -f value -c floating_ip_address)
fi

echo "Bastion IP: $BASTION_IP"
echo "Proxy IP: $PROXY_IP"

# ---- KEYPAIR ----
if ! openstack keypair show ${TAG}_key &>/dev/null; then
    openstack keypair create --public-key ${SSH_KEY}.pub ${TAG}_key
fi

# ---- NETWORK ----
if ! openstack network show ${TAG}_network &>/dev/null; then
    openstack network create ${TAG}_network
    openstack subnet create --network ${TAG}_network --subnet-range 192.168.1.0/24 ${TAG}_subnet
fi

# ---- ROUTER ----
if ! openstack router show ${TAG}_router &>/dev/null; then
    openstack router create ${TAG}_router
fi

openstack router set --external-gateway External ${TAG}_router
openstack router add subnet ${TAG}_router ${TAG}_subnet 2>/dev/null

# ---- SECURITY GROUP ----
if ! openstack security group show ${TAG}_sg &>/dev/null; then
    openstack security group create ${TAG}_sg
fi

openstack security group rule create --proto tcp --dst-port 22 ${TAG}_sg 2>/dev/null
openstack security group rule create --proto tcp --dst-port 5000 ${TAG}_sg 2>/dev/null
openstack security group rule create --proto udp --dst-port 6000 ${TAG}_sg 2>/dev/null
openstack security group rule create --proto icmp ${TAG}_sg 2>/dev/null

# ---- IMAGE & FLAVOR ----
IMAGE=$(openstack image list -f value -c Name | grep -i "Ubuntu 20.04" | head -1)
FLAVOR="small"

# ---- CREATE SERVERS ----
create_server() {
    NAME=$1
    if ! openstack server show $NAME &>/dev/null; then
        openstack server create --image "$IMAGE" --flavor $FLAVOR \
            --key-name ${TAG}_key \
            --network ${TAG}_network \
            --security-group ${TAG}_sg \
            $NAME
    fi
}

create_server ${TAG}_bastion
create_server ${TAG}_proxy

for i in $(seq 1 $NODE_COUNT); do
    create_server ${TAG}_node${i}
done

# ---- WAIT FOR ACTIVE ----
echo "Waiting for servers..."
sleep 30

# ---- ATTACH FLOATING IP ----
openstack server add floating ip ${TAG}_bastion $BASTION_IP
openstack server add floating ip ${TAG}_proxy $PROXY_IP

# ---- GENERATE HOSTS FILE ----
mkdir -p ansible

cat > ansible/hosts.cfg << HOSTS
[bastion]
bastion_host ansible_host=$BASTION_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[proxy]
proxy_host ansible_host=$PROXY_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[nodes]
HOSTS

for i in $(seq 1 $NODE_COUNT); do
    NODE_IP=$(openstack server show ${TAG}_node${i} -f value -c addresses | grep -oP '[\d.]+' | head -1)
    if [ -n "$NODE_IP" ]; then
        echo "node${i} ansible_host=$NODE_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyJump=ubuntu@$BASTION_IP'" >> ansible/hosts.cfg
    fi
done

echo "Generated hosts.cfg:"
cat ansible/hosts.cfg

# ---- WAIT FOR SSH ----
echo "Waiting for SSH..."
sleep 30

# ---- TEST ----
export ANSIBLE_HOST_KEY_CHECKING=False
ansible all -i ansible/hosts.cfg -m ping

echo "Deployment complete!"