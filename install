#!/bin/bash

if [ "$#" -ne 3 ]; then
    echo "Usage: ./install <openrc> <tag> <ssh_key>"
    exit 1
fi

OPENRC=$1
TAG=$2
SSH_KEY=$3

source $OPENRC
echo "$(date '+%Y-%m-%d %H:%M:%S') Starting deployment of $TAG"

# ---- NODE COUNT ----
NODE_COUNT=$(grep -E '^[0-9]+$' servers.conf | head -1)
echo "$(date '+%Y-%m-%d %H:%M:%S') Node count: $NODE_COUNT"

# ---- AUTO DETECT EXTERNAL NETWORK ----
EXT_NET=$(openstack network list --external -f value -c ID | head -n 1)
echo "$(date '+%Y-%m-%d %H:%M:%S') External network: $EXT_NET"

# ---- AUTO DETECT FLAVORS ----
FLAVOR_SMALL=$(openstack flavor list -f value -c Name | grep -i small | head -1)
FLAVOR_TINY=$(openstack flavor list -f value -c Name | grep -i tiny | head -1)
echo "$(date '+%Y-%m-%d %H:%M:%S') Flavors: small=$FLAVOR_SMALL tiny=$FLAVOR_TINY"

# ---- KEYPAIR ----
if ! openstack keypair show ${TAG}_key &>/dev/null; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Creating keypair..."
    openstack keypair create --public-key ${SSH_KEY}.pub ${TAG}_key > /dev/null
fi

# ---- NETWORK ----
if ! openstack network show ${TAG}_network &>/dev/null; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Creating network..."
    openstack network create ${TAG}_network > /dev/null
    openstack subnet create \
        --network ${TAG}_network \
        --subnet-range 192.168.1.0/24 \
        --dns-nameserver 8.8.8.8 \
        ${TAG}_subnet > /dev/null
    openstack network set --tag $TAG ${TAG}_network 2>/dev/null || true
fi

NETWORK_ID=$(openstack network show ${TAG}_network -f value -c id)

# ---- ROUTER ----
if ! openstack router show ${TAG}_router &>/dev/null; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Creating router..."
    openstack router create ${TAG}_router > /dev/null
fi
openstack router set --external-gateway $EXT_NET ${TAG}_router 2>/dev/null || true
openstack router add subnet ${TAG}_router ${TAG}_subnet 2>/dev/null || true
openstack router set --tag $TAG ${TAG}_router 2>/dev/null || true

# ---- SECURITY GROUP ----
if ! openstack security group show ${TAG}_sg &>/dev/null; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Creating security group..."
    openstack security group create ${TAG}_sg > /dev/null
    openstack security group rule create --proto tcp --dst-port 22 ${TAG}_sg > /dev/null
    openstack security group rule create --proto tcp --dst-port 5000 ${TAG}_sg > /dev/null
    openstack security group rule create --proto udp --dst-port 6000 ${TAG}_sg > /dev/null
    openstack security group rule create --proto icmp ${TAG}_sg > /dev/null
    openstack security group set --tag $TAG ${TAG}_sg 2>/dev/null || true
fi

# ---- FLOATING IPs ----
AVAILABLE_IPS=$(openstack floating ip list --status DOWN -f value -c "Floating IP Address")
IP_COUNT=$(echo "$AVAILABLE_IPS" | grep -c '[0-9]' || true)

if [ "$IP_COUNT" -ge 2 ]; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Reusing existing floating IPs..."
    BASTION_IP=$(echo "$AVAILABLE_IPS" | sed -n '1p')
    PROXY_IP=$(echo "$AVAILABLE_IPS" | sed -n '2p')
else
    echo "$(date '+%Y-%m-%d %H:%M:%S') Allocating floating IPs..."
    BASTION_IP=$(openstack floating ip create $EXT_NET -f value -c floating_ip_address)
    PROXY_IP=$(openstack floating ip create $EXT_NET -f value -c floating_ip_address)
fi
echo "$(date '+%Y-%m-%d %H:%M:%S') Bastion IP: $BASTION_IP, Proxy IP: $PROXY_IP"

# ---- IMAGE ----
IMAGE=$(openstack image list -f value -c Name | grep -i "Ubuntu 20.04" | head -1)
[ -z "$IMAGE" ] && echo "ERROR: No Ubuntu image found" && exit 1

# ---- CREATE SERVERS ----
create_server() {
    NAME=$1
    FLAV=$2
    if ! openstack server show $NAME &>/dev/null; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') Launching $NAME with flavor $FLAV"
        openstack server create \
            --image "$IMAGE" \
            --flavor $FLAV \
            --key-name ${TAG}_key \
            --network $NETWORK_ID \
            --security-group ${TAG}_sg \
            $NAME > /dev/null
    else
        echo "$(date '+%Y-%m-%d %H:%M:%S') $NAME already exists"
    fi
}

create_server ${TAG}_bastion $FLAVOR_SMALL
create_server ${TAG}_proxy $FLAVOR_SMALL

for i in $(seq 1 $NODE_COUNT); do
    create_server ${TAG}_node${i} $FLAVOR_TINY
done

# ---- WAIT FOR ACTIVE ----
echo "$(date '+%Y-%m-%d %H:%M:%S') Waiting for all servers to become ACTIVE..."
for SERVER in ${TAG}_bastion ${TAG}_proxy $(seq 1 $NODE_COUNT | xargs -I{} echo ${TAG}_node{}); do
    while true; do
        STATUS=$(openstack server show $SERVER -f value -c status 2>/dev/null)
        if [ "$STATUS" = "ACTIVE" ]; then
            echo -n "[$SERVER done]"
            break
        fi
        sleep 5
    done
done
echo ""
echo "$(date '+%Y-%m-%d %H:%M:%S') All servers ACTIVE."

# ---- ATTACH FLOATING IPs ----
openstack server add floating ip ${TAG}_bastion $BASTION_IP 2>/dev/null || true
openstack server add floating ip ${TAG}_proxy $PROXY_IP 2>/dev/null || true
echo "$(date '+%Y-%m-%d %H:%M:%S') Floating IPs attached."

# ---- WAIT FOR SSH ----
echo "$(date '+%Y-%m-%d %H:%M:%S') Waiting for SSH to be ready..."
for i in $(seq 1 18); do
    sleep 10
    if ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o ConnectTimeout=5 ubuntu@$BASTION_IP "echo ok" &>/dev/null; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') Bastion SSH ready after $((i*10))s"
        break
    fi
    echo -n "."
done

# Wait for nodes to be reachable through bastion
echo "$(date '+%Y-%m-%d %H:%M:%S') Waiting for nodes to be reachable..."
for i in $(seq 1 18); do
    sleep 10
    NODE1_IP=$(openstack server show ${TAG}_node1 -f value -c addresses | grep -oP '[\d.]+' | head -1)
    if ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o ConnectTimeout=5 \
        -o ProxyCommand="ssh -i $SSH_KEY -W %h:%p -o StrictHostKeyChecking=no ubuntu@$BASTION_IP" \
        ubuntu@$NODE1_IP "echo ok" &>/dev/null; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') Nodes ready after $((i*10))s"
        break
    fi
    echo -n "."
done

# ---- GET NODE IPs ----
BASTION_INTERNAL=$(openstack server show ${TAG}_bastion -f value -c addresses | grep -oP '[\d.]+' | head -1)
PROXY_INTERNAL=$(openstack server show ${TAG}_proxy -f value -c addresses | grep -oP '[\d.]+' | head -1)

# ---- GENERATE SSH CONFIG ----
echo "$(date '+%Y-%m-%d %H:%M:%S') Generating SSH config..."
SSH_CONFIG="${TAG}_SSHconfig"

cat > $SSH_CONFIG << SSHEOF
Host ${TAG}_bastion
    HostName $BASTION_IP
    User ubuntu
    IdentityFile $SSH_KEY
    StrictHostKeyChecking no

Host ${TAG}_proxy
    HostName $PROXY_INTERNAL
    User ubuntu
    IdentityFile $SSH_KEY
    StrictHostKeyChecking no
    ProxyJump ${TAG}_bastion

SSHEOF

for i in $(seq 1 $NODE_COUNT); do
    NODE_IP=$(openstack server show ${TAG}_node${i} -f value -c addresses | grep -oP '[\d.]+' | head -1)
    cat >> $SSH_CONFIG << SSHEOF
Host ${TAG}_node${i}
    HostName $NODE_IP
    User ubuntu
    IdentityFile $SSH_KEY
    StrictHostKeyChecking no
    ProxyJump ${TAG}_bastion

SSHEOF
done

echo "$(date '+%Y-%m-%d %H:%M:%S') SSH config saved to $SSH_CONFIG"

# ---- GENERATE ANSIBLE HOSTS ----
echo "$(date '+%Y-%m-%d %H:%M:%S') Generating Ansible hosts file..."
mkdir -p ansible

cat > ansible/hosts << HOSTS
[bastion]
bastion ansible_host=$BASTION_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[proxy]
proxy ansible_host=$PROXY_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -i $SSH_KEY -W %h:%p -o StrictHostKeyChecking=no ubuntu@$BASTION_IP"'

[nodes]
HOSTS

for i in $(seq 1 $NODE_COUNT); do
    NODE_IP=$(openstack server show ${TAG}_node${i} -f value -c addresses | grep -oP '[\d.]+' | head -1)
    if [ -n "$NODE_IP" ]; then
        echo "node${i} ansible_host=$NODE_IP ansible_user=ubuntu ansible_ssh_private_key_file=$SSH_KEY ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand=\"ssh -i $SSH_KEY -W %h:%p -o StrictHostKeyChecking=no ubuntu@$BASTION_IP\"'" >> ansible/hosts
    fi
done

echo "$(date '+%Y-%m-%d %H:%M:%S') hosts file generated."

# ---- RUN ANSIBLE ----
export ANSIBLE_HOST_KEY_CHECKING=False
echo "$(date '+%Y-%m-%d %H:%M:%S') Running Ansible playbook..."

for attempt in 1 2 3; do
    echo "$(date '+%Y-%m-%d %H:%M:%S') Ansible attempt $attempt..."
    ansible-playbook -i ansible/hosts ansible/site.yml && break
    echo "$(date '+%Y-%m-%d %H:%M:%S') Attempt $attempt failed, waiting 30s..."
    sleep 30
done

# ---- VALIDATE ----
echo "$(date '+%Y-%m-%d %H:%M:%S') Validating deployment..."
for i in 1 2 3; do
    RESPONSE=$(curl -s http://$PROXY_IP:5000)
    echo "$(date '+%Y-%m-%d %H:%M:%S') Request$i: $RESPONSE"
done

echo "$(date '+%Y-%m-%d %H:%M:%S') Deployment complete! Bastion: $BASTION_IP Proxy: $PROXY_IP"
